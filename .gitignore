# ═══════════════════════════════════════════════════════════
# .gitignore - Máquina de Programación de Sueños CECyTE 04
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
venv/
env/
ENV/

# ═══════════════════════════════════════════════════════════
# Node.js / React
# ═══════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
coverage/
build/
.cache/

# ═══════════════════════════════════════════════════════════
# Environment Variables (IMPORTANTE)
# ═══════════════════════════════════════════════════════════
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Permitir plantillas de ejemplo
!.env.example
!.env.template

# ═══════════════════════════════════════════════════════════
# IDE / Editors
# ═══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ═══════════════════════════════════════════════════════════
# OS Files
# ═══════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ═══════════════════════════════════════════════════════════
# Testing
# ═══════════════════════════════════════════════════════════
coverage/
.nyc_output/
test_reports/
*.coverage
.pytest_cache/
.tox/

# ═══════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3

# ═══════════════════════════════════════════════════════════
# Uploads (Modelos 3D)
# Mantener carpeta pero ignorar archivos subidos
# ═══════════════════════════════════════════════════════════
backend/uploads/models/*
!backend/uploads/models/.gitkeep

# ═══════════════════════════════════════════════════════════
# Backups y Temporales
# ═══════════════════════════════════════════════════════════
*.bak
*.backup
*.tmp
*.temp
*_backup.*
*_old.*

# ═══════════════════════════════════════════════════════════
# Emergent Platform (No modificar)
# ═══════════════════════════════════════════════════════════
.emergent/

# ═══════════════════════════════════════════════════════════
# Archivos Específicos del Proyecto (No subir)
# ═══════════════════════════════════════════════════════════
backend/server_mongodb_backup.py
backend_test.py
auth_testing.md
test_result.md
design_guidelines.json
-e 
