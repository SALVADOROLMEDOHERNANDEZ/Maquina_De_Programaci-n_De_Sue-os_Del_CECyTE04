# ═══════════════════════════════════════════════════════════
# ARCHIVO DE EJEMPLO - Copiar a .env y completar con tus valores
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS - MySQL / phpMyAdmin (Compatible con Hostinger)
# ═══════════════════════════════════════════════════════════

# Configuración MySQL Local (Desarrollo)
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DATABASE="cecyte04_dreams"

# Configuración para Hostinger (Producción)
# Descomentar y completar con tus credenciales de Hostinger:
# MYSQL_HOST="mysql-xxxxx.servers.hostinger.com"
# MYSQL_USER="u123456789_cecyte04"
# MYSQL_PASSWORD="tu_contraseña_segura"
# MYSQL_DATABASE="u123456789_cecyte04_dreams"

CORS_ORIGINS="*"

# ═══════════════════════════════════════════════════════════
# API KEYS GRATUITAS (¡Obligatorio para IA!)
# ═══════════════════════════════════════════════════════════

# Google Gemini (Para generación de historias) - GRATIS
# Cómo obtener: https://aistudio.google.com
# 1. Ir al sitio
# 2. Iniciar sesión con Google
# 3. Clic en "Get API Key"
# 4. Crear en nuevo proyecto
# 5. Copiar la clave generada
GOOGLE_GEMINI_API_KEY=""

# Hugging Face (Para generación de imágenes) - GRATIS
# Cómo obtener: https://huggingface.co/settings/tokens
# 1. Crear cuenta o iniciar sesión
# 2. Ir a Settings > Access Tokens
# 3. New token > Fine-grained
# 4. Activar "Make calls to inference providers"
# 5. Copiar el token generado (empieza con hf_)
HUGGINGFACE_API_TOKEN=""

# ═══════════════════════════════════════════════════════════
# Credenciales de Admin
# ═══════════════════════════════════════════════════════════
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cecyte04admin"
ADMIN_EMAILS="olmedohernandezsalvador@gmail.com"

# ═══════════════════════════════════════════════════════════
# Servicios Opcionales (SendGrid y Twilio)
# Solo necesarios si quieres enviar historias por email/WhatsApp
# ═══════════════════════════════════════════════════════════

# SendGrid (Opcional - para envío de emails)
# https://sendgrid.com
SENDGRID_API_KEY=""
SENDER_EMAIL=""

# Twilio (Opcional - para WhatsApp)
# https://twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ═══════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ═══════════════════════════════════════════════════════════
# 
# 1. NO SUBIR ESTE ARCHIVO A GIT
#    - Renombrar a .env (sin .example)
#    - El archivo .env está en .gitignore
#
# 2. APIS GRATUITAS
#    - Google Gemini: 15 requests/minuto, 1,500/día (GRATIS)
#    - Hugging Face: Créditos mensuales renovables (GRATIS)
#    - No requieren tarjeta de crédito
#
# 3. PRODUCCIÓN EN HOSTINGER
#    - Cambiar MYSQL_* con credenciales de Hostinger
#    - Obtener credenciales en Panel Hostinger > Bases de Datos
#    - Importar database_schema.sql en phpMyAdmin
#
# 4. MÁS INFORMACIÓN
#    - Ver: CONFIGURACION_IA_GRATIS.md
#    - Ver: MIGRACION_MYSQL.md
#    - Ver: INSTALL.md
# ═══════════════════════════════════════════════════════════
